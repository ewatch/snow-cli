/target
/book
*.swp
*.swo
*~
.DS_Store
.env
.env.*
!.env.example

# E2E / release run artifacts (may contain only best-effort-redacted instance
# output) — never commit; regenerated by scripts/e2e-run and release-pipeline
artifacts/

# Rendered video frames/assets — never commit
video/

# Local tool caches (codebase-memory / tokensave MCP servers, serena) — never commit
.codebase-memory/
.tokensave/
.serena/

# scripts/e2e-snu-harness is npm-installed on demand by scripts/e2e-run
# (only when SNOW_E2E_SN_UTILS=1) — package-lock.json is committed, the
# installed tree is not.
scripts/e2e-snu-harness/node_modules/
