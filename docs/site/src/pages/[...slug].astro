---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../layouts/DocsLayout.astro';
import { flatNav, routeForEntry } from '../navigation';

export async function getStaticPaths() {
  const entries = await getCollection('docs');
  return entries.map((entry) => ({
    // The site root is the static landing page in public/; all chapters get their own route.
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const route = routeForEntry(entry.id);
const navItem = flatNav.find((item) => item.href === route);
const title = headings.find((h) => h.depth === 1)?.text ?? navItem?.label ?? entry.id;
---

<DocsLayout title={title} headings={headings}>
  <Content />
</DocsLayout>
