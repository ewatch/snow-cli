---
import { sidebar, flatNav } from '../navigation';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description?: string;
  headings?: Heading[];
}

const { title, description, headings = [] } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (href: string) => `${base}${href}` || '/';

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => {
  const target = withBase(href).replace(/\/$/, '') || '/';
  return target === currentPath;
};

const flatIndex = flatNav.findIndex((item) => isActive(item.href));
const prev = flatIndex > 0 ? flatNav[flatIndex - 1] : undefined;
const next = flatIndex >= 0 && flatIndex < flatNav.length - 1 ? flatNav[flatIndex + 1] : undefined;

const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
const pageTitle = title === 'Introduction' ? 'snow-cli Documentation' : `${title} | snow-cli Documentation`;
const metaDescription =
  description ?? 'Documentation for snow-cli, a ServiceNow CLI for humans and coding agents.';
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const socialImageUrl = new URL(`${base}/social-preview.png`, Astro.site).href;
const logoUrl = new URL(`${base}/logo.png`, Astro.site).href;
---

<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{pageTitle}</title>
<meta name="description" content={metaDescription} />
<meta name="robots" content="index, follow" />
<meta name="theme-color" content="#08100d" />
<link rel="canonical" href={canonicalUrl} />
<meta property="og:type" content="website" />
<meta property="og:locale" content="en_US" />
<meta property="og:site_name" content="snow-cli" />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={metaDescription} />
<meta property="og:image" content={socialImageUrl} />
<meta property="og:image:secure_url" content={socialImageUrl} />
<meta property="og:image:type" content="image/png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="snow-cli terminal logo" />
<meta property="og:logo" content={logoUrl} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={metaDescription} />
<meta name="twitter:image" content={socialImageUrl} />
<meta name="twitter:image:alt" content="snow-cli terminal logo" />
<link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
<link rel="apple-touch-icon" href={withBase('/logo.png')} />
<link rel="stylesheet" href={withBase('/pagefind/pagefind-ui.css')} />
<style is:global>
  :root {
    --ink: #edf6f0;
    --ink-muted: #a6b8ad;
    --ink-faint: #71847a;
    --paper: #08100d;
    --paper-raised: #0d1713;
    --paper-soft: #111e18;
    --line: #21342a;
    --line-bright: #31503d;
    --signal: #9ee493;
    --signal-dark: #193522;
    --cyan: #79d5d0;
    --amber: #e8c477;
    --danger: #ff8f82;
    --danger-dark: #351714;
    --mono: "SFMono-Regular", "Cascadia Code", "Liberation Mono", Menlo, monospace;
    --sans: "Avenir Next", Avenir, "Segoe UI", sans-serif;
    --shadow: 0 30px 90px rgba(0, 0, 0, .42);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    background:
      linear-gradient(rgba(158, 228, 147, .025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(158, 228, 147, .025) 1px, transparent 1px),
      var(--paper);
    background-size: 42px 42px;
    color: var(--ink);
    font-family: var(--sans);
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }
  a { color: inherit; text-decoration: none; }
  button, a { -webkit-tap-highlight-color: transparent; }
  ::selection { background: rgba(158, 228, 147, .22); color: var(--ink); }
  code, pre { font-family: var(--mono); }

  .wrap { width: min(1240px, calc(100% - 48px)); margin: 0 auto; }

  /* ---------- Top navigation (from the landing page) ---------- */
  nav.top {
    position: sticky;
    top: 0;
    z-index: 20;
    border-bottom: 1px solid rgba(49, 80, 61, .72);
    background: rgba(8, 16, 13, .82);
    backdrop-filter: blur(16px);
  }
  .nav-inner { min-height: 66px; display: flex; align-items: center; justify-content: space-between; gap: 28px; }
  .brand { display: inline-flex; align-items: center; gap: 11px; font: 700 16px/1 var(--mono); letter-spacing: -.02em; }
  .brand .docs-tag { color: var(--ink-faint); font-weight: 500; }
  .mark {
    width: 31px;
    height: 31px;
    display: grid;
    place-items: center;
    border: 1px solid var(--signal);
    border-radius: 6px 11px 6px 11px;
    color: var(--signal);
    background: var(--signal-dark);
    box-shadow: 0 0 24px rgba(158, 228, 147, .12);
  }
  .nav-links { display: flex; align-items: center; gap: 18px; color: var(--ink-muted); font-size: 13.5px; }
  .nav-links a:hover, .nav-links a:focus-visible { color: var(--ink); }
  .release-badge { border: 1px solid var(--line-bright); border-radius: 999px; padding: 4px 9px; color: var(--signal); font: 11px/1.3 var(--mono); white-space: nowrap; }
  .nav-cta { border: 1px solid var(--line-bright); border-radius: 7px; padding: 7px 13px; color: var(--ink) !important; }
  .github-link { width: 34px; min-height: 34px; padding: 7px; }
  .github-link svg { display: block; width: 18px; height: 18px; fill: currentColor; }
  .menu-toggle {
    display: none;
    border: 1px solid var(--line-bright);
    border-radius: 7px;
    background: rgba(13, 23, 19, .7);
    color: var(--ink);
    font: 700 12px/1 var(--mono);
    padding: 9px 13px;
    cursor: pointer;
  }

  /* ---------- Docs shell ---------- */
  .shell {
    display: grid;
    grid-template-columns: 258px minmax(0, 1fr) 218px;
    gap: 56px;
    align-items: start;
    padding: 44px 0 90px;
  }

  /* ---------- Sidebar search (Pagefind) ---------- */
  .sidebar-search {
    --pagefind-ui-scale: .8;
    --pagefind-ui-primary: var(--signal);
    --pagefind-ui-text: var(--ink);
    --pagefind-ui-background: var(--paper-raised);
    --pagefind-ui-border: var(--line-bright);
    --pagefind-ui-tag: var(--paper-soft);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-font: var(--sans);
    margin-bottom: 26px;
  }
  .sidebar-search .pagefind-ui__search-input { font-family: var(--mono); font-size: 13px; }
  .sidebar-search .pagefind-ui__result-title a { color: var(--cyan); }
  .sidebar-search .pagefind-ui__result-link { color: var(--cyan); }

  /* ---------- Sidebar ---------- */
  .sidebar {
    position: sticky;
    top: 98px;
    max-height: calc(100vh - 130px);
    overflow-y: auto;
    padding-right: 10px;
    scrollbar-width: thin;
    scrollbar-color: var(--line-bright) transparent;
  }
  .side-group { margin-bottom: 30px; }
  .side-group > h2 {
    color: var(--signal);
    font: 700 11px/1.4 var(--mono);
    letter-spacing: .14em;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .side-group ul { list-style: none; }
  .side-group ul ul { margin: 2px 0 6px; padding-left: 13px; border-left: 1px solid var(--line); }
  .side-group a {
    display: block;
    padding: 5px 10px;
    border-radius: 6px;
    color: var(--ink-muted);
    font-size: 13.5px;
    line-height: 1.45;
    border: 1px solid transparent;
  }
  .side-group ul ul a { font-family: var(--mono); font-size: 12.5px; }
  .side-group a:hover, .side-group a:focus-visible { color: var(--ink); background: rgba(13, 23, 19, .8); }
  .side-group a[aria-current="page"] {
    color: var(--signal);
    background: var(--signal-dark);
    border-color: var(--line-bright);
  }

  /* ---------- Article prose ---------- */
  .doc { min-width: 0; }
  .prose { max-width: 74ch; }
  .prose > :first-child { margin-top: 0; }
  .prose h1 {
    font-size: clamp(2.1rem, 4vw, 2.9rem);
    line-height: 1.05;
    letter-spacing: -.045em;
    margin-bottom: 22px;
    text-wrap: balance;
  }
  .prose h2 {
    font-size: 1.45rem;
    letter-spacing: -.03em;
    margin: 52px 0 14px;
    padding-top: 28px;
    border-top: 1px solid var(--line);
    text-wrap: balance;
  }
  .prose h3 { font-size: 1.12rem; letter-spacing: -.02em; margin: 34px 0 10px; }
  .prose h4 { font-size: .95rem; margin: 26px 0 8px; color: var(--ink-muted); }
  .prose h1 code, .prose h2 code, .prose h3 code { font-size: .92em; color: inherit; background: none; border: none; padding: 0; white-space: normal; overflow-wrap: anywhere; }
  .prose p { margin: 14px 0; color: var(--ink-muted); }
  .prose strong { color: var(--ink); font-weight: 650; }
  .prose a {
    color: var(--cyan);
    border-bottom: 1px solid rgba(121, 213, 208, .35);
    transition: border-color .15s ease;
  }
  .prose a:hover { border-bottom-color: var(--cyan); }
  .prose ul, .prose ol { margin: 14px 0; padding-left: 26px; color: var(--ink-muted); }
  .prose li { margin: 6px 0; }
  .prose li::marker { color: var(--signal); }
  .prose code {
    background: rgba(158, 228, 147, .07);
    border: 1px solid var(--line);
    border-radius: 5px;
    padding: 1.5px 6px;
    font-size: .86em;
    color: var(--amber);
    white-space: nowrap;
  }
  .prose blockquote {
    margin: 22px 0;
    padding: 14px 20px;
    border-left: 3px solid var(--signal);
    border-radius: 0 9px 9px 0;
    background: var(--paper-raised);
  }
  .prose blockquote p { margin: 6px 0; }
  .prose hr { border: none; border-top: 1px solid var(--line); margin: 40px 0; }

  /* Code blocks styled like the landing's console cards */
  .prose pre {
    position: relative;
    margin: 24px 0;
    padding: 56px 0 18px;
    border: 1px solid var(--line-bright);
    border-radius: 13px;
    background: rgba(8, 15, 12, .94) !important;
    box-shadow: var(--shadow);
    overflow: hidden;
    font-size: 13px;
    line-height: 1.85;
  }
  .prose pre::before {
    content: "";
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 40px;
    border-bottom: 1px solid var(--line);
    border-radius: 13px 13px 0 0;
    background:
      radial-gradient(circle 4.5px at 21px 20px, #d47770 97%, transparent),
      radial-gradient(circle 4.5px at 37px 20px, var(--amber) 97%, transparent),
      radial-gradient(circle 4.5px at 53px 20px, var(--signal) 97%, transparent),
      var(--paper-raised);
  }
  .prose pre::after {
    content: attr(data-language);
    position: absolute;
    top: 14px; left: 70px;
    color: var(--ink-faint);
    font: 11px/1 var(--mono);
  }
  .prose pre code {
    display: block;
    overflow-x: auto;
    padding: 0 20px;
    background: none;
    border: none;
    font-size: inherit;
    color: inherit;
    white-space: pre;
  }

  /* Tables */
  .prose table {
    width: 100%;
    margin: 22px 0;
    border-collapse: collapse;
    border: 1px solid var(--line-bright);
    border-radius: 10px;
    overflow: hidden;
    font-size: 13.5px;
  }
  .prose th {
    background: var(--paper-raised);
    color: var(--signal);
    font: 700 11px/1.5 var(--mono);
    letter-spacing: .1em;
    text-transform: uppercase;
    text-align: left;
    padding: 10px 14px;
    border-bottom: 1px solid var(--line-bright);
  }
  .prose td { padding: 9px 14px; border-bottom: 1px solid var(--line); color: var(--ink-muted); vertical-align: top; }
  .prose tr:last-child td { border-bottom: none; }
  .prose tr:nth-child(even) td { background: rgba(13, 23, 19, .5); }

  /* ---------- Prev / next pagination ---------- */
  .pager { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-top: 64px; max-width: 74ch; }
  .pager a {
    display: block;
    border: 1px solid var(--line-bright);
    border-radius: 10px;
    background: rgba(13, 23, 19, .7);
    padding: 14px 18px;
    transition: transform .18s ease, border-color .18s ease;
  }
  .pager a:hover { transform: translateY(-2px); border-color: var(--signal); }
  .pager a.next { grid-column: 2; text-align: right; }
  .pager .pager-label { color: var(--ink-faint); font: 700 10.5px/1.4 var(--mono); letter-spacing: .14em; text-transform: uppercase; }
  .pager .pager-title { color: var(--ink); font-size: 14px; font-weight: 650; margin-top: 3px; }

  /* ---------- On-this-page rail ---------- */
  .toc { position: sticky; top: 98px; max-height: calc(100vh - 130px); overflow-y: auto; font-size: 12.5px; }
  .toc h2 {
    color: var(--signal);
    font: 700 11px/1.4 var(--mono);
    letter-spacing: .14em;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .toc ul { list-style: none; border-left: 1px solid var(--line); }
  .toc a {
    display: block;
    padding: 4px 0 4px 13px;
    color: var(--ink-faint);
    border-left: 1px solid transparent;
    margin-left: -1px;
    line-height: 1.45;
  }
  .toc a:hover { color: var(--ink); }
  .toc li[data-depth="3"] a { padding-left: 26px; }

  /* ---------- Footer (from the landing page) ---------- */
  footer { border-top: 1px solid var(--line); padding: 36px 0; color: var(--ink-faint); font-size: 13px; }
  .footer-inner { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 18px; }
  .footer-links { display: flex; gap: 20px; }
  .footer-links a:hover { color: var(--ink); }

  /* ---------- Responsive ---------- */
  @media (max-width: 1120px) {
    .shell { grid-template-columns: 240px minmax(0, 1fr); gap: 42px; }
    .toc { display: none; }
  }
  @media (max-width: 820px) {
    .menu-toggle { display: inline-flex; }
    .nav-links .hide-mobile { display: none; }
    .shell { display: block; padding-top: 26px; }
    .sidebar {
      display: none;
      position: static;
      max-height: none;
      margin-bottom: 34px;
      padding: 18px 18px 6px;
      border: 1px solid var(--line-bright);
      border-radius: 13px;
      background: var(--paper-raised);
    }
    body.nav-open .sidebar { display: block; }
    .pager { grid-template-columns: 1fr; }
    .pager a.next { grid-column: auto; text-align: left; }
  }
  @media (prefers-reduced-motion: reduce) {
    html { scroll-behavior: auto; }
    *, *::before, *::after { transition-duration: .01ms !important; }
  }
</style>
</head>
<body>

<nav class="top" aria-label="Primary navigation">
  <div class="wrap nav-inner">
    <a class="brand" href={withBase('/')} aria-label="snow-cli documentation home">
      <span class="mark" aria-hidden="true">&gt;_</span> snow-cli <span class="docs-tag">/ docs</span>
    </a>
    <div class="nav-links">
      <a class="hide-mobile" href={withBase('/quick-start/')}>Quick start</a>
      <a class="hide-mobile" href={withBase('/commands/')}>Commands</a>
      <span class="release-badge hide-mobile">v0.6.0</span>
      <a class="nav-cta github-link" href="https://github.com/ewatch/snow-cli" aria-label="snow-cli on GitHub">
        <svg viewBox="0 0 16 16" aria-hidden="true" focusable="false"><path fill-rule="evenodd" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
      </a>
      <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="sidebar">Menu</button>
    </div>
  </div>
</nav>

<div class="wrap shell">
  <aside class="sidebar" id="sidebar" aria-label="Documentation navigation">
    <div class="sidebar-search" id="docs-search" data-pagefind-ignore></div>
    {sidebar.map((group) => (
      <div class="side-group">
        <h2>{group.label}</h2>
        <ul>
          {group.items.map((item) => (
            <li>
              <a href={withBase(item.href)} aria-current={isActive(item.href) ? 'page' : undefined}>{item.label}</a>
              {item.children && (
                <ul>
                  {item.children.map((child) => (
                    <li>
                      <a href={withBase(child.href)} aria-current={isActive(child.href) ? 'page' : undefined}>{child.label}</a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))}
        </ul>
      </div>
    ))}
  </aside>

  <main class="doc">
    <article class="prose" data-pagefind-body>
      <slot />
    </article>
    {(prev || next) && (
      <nav class="pager" aria-label="Previous and next pages">
        {prev && (
          <a href={withBase(prev.href)} rel="prev">
            <span class="pager-label">&larr; Previous</span>
            <span class="pager-title" style="display:block">{prev.label}</span>
          </a>
        )}
        {next && (
          <a class="next" href={withBase(next.href)} rel="next">
            <span class="pager-label">Next &rarr;</span>
            <span class="pager-title" style="display:block">{next.label}</span>
          </a>
        )}
      </nav>
    )}
  </main>

  {toc.length > 0 && (
    <aside class="toc" aria-label="On this page">
      <h2>On this page</h2>
      <ul>
        {toc.map((heading) => (
          <li data-depth={heading.depth}>
            <a href={`#${heading.slug}`}>{heading.text}</a>
          </li>
        ))}
      </ul>
    </aside>
  )}
</div>

<footer>
  <div class="wrap footer-inner">
    <span>snow-cli 0.6.0 / MIT licensed / written in Rust</span>
    <span class="footer-links">
      <a href="https://github.com/ewatch/snow-cli">GitHub</a>
      <a href={withBase('/introduction/')}>Documentation</a>
      <a href={withBase('/secure-readonly-usage/')}>Read-only guide</a>
      <a href={withBase('/llms.txt')}>llms.txt</a>
    </span>
  </div>
</footer>

<script>
  const toggle = document.querySelector('.menu-toggle');
  toggle?.addEventListener('click', () => {
    const open = document.body.classList.toggle('nav-open');
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>

<script src={withBase('/pagefind/pagefind-ui.js')} is:inline></script>
<script define:vars={{ bundlePath: withBase('/pagefind/') }}>
  // Pagefind assets are generated at build time (npm run build → postbuild),
  // so search is inert under `astro dev` and active in preview/production.
  window.addEventListener('DOMContentLoaded', () => {
    if (typeof PagefindUI === 'undefined') return;
    new PagefindUI({
      element: '#docs-search',
      bundlePath,
      showSubResults: true,
      showImages: false,
      resetStyles: false,
      translations: { placeholder: 'Search the docs' },
    });
  });
</script>

</body>
</html>
